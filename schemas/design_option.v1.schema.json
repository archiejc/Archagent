{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archagent.local/schemas/design_option.v1.schema.json",
  "title": "Design Option V1",
  "type": "object",
  "required": [
    "variant_id",
    "source_plan_id",
    "gh_definition",
    "param_vector",
    "geometry_ref",
    "preview_ref",
    "kpi",
    "constraint_pass",
    "object_guid_map",
    "coordinate_meta",
    "geometry_objects"
  ],
  "additionalProperties": false,
  "properties": {
    "variant_id": {
      "type": "string",
      "pattern": "^v_[A-Za-z0-9_-]+$"
    },
    "source_plan_id": {
      "type": "string",
      "minLength": 1
    },
    "gh_definition": {
      "type": "string",
      "minLength": 1
    },
    "param_vector": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "number"
      }
    },
    "geometry_ref": {
      "type": "object",
      "required": ["rhino_3dm"],
      "additionalProperties": false,
      "properties": {
        "rhino_3dm": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "preview_ref": {
      "type": "object",
      "required": ["birdview_png", "siteplan_png"],
      "additionalProperties": false,
      "properties": {
        "birdview_png": {
          "type": "string",
          "minLength": 1
        },
        "siteplan_png": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "kpi": {
      "type": "object",
      "required": ["roi", "carbon_proxy", "public_space_ratio", "fairness_proxy"],
      "additionalProperties": {
        "type": "number"
      },
      "properties": {
        "roi": {"type": "number"},
        "carbon_proxy": {"type": "number"},
        "public_space_ratio": {"type": "number"},
        "fairness_proxy": {"type": "number"}
      }
    },
    "constraint_pass": {
      "type": "boolean"
    },
    "object_guid_map": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "coordinate_meta": {
      "type": "object",
      "required": ["strategy"],
      "additionalProperties": false,
      "properties": {
        "strategy": {
          "type": "string",
          "enum": ["dual", "local_only", "geo_only"]
        },
        "transform_info": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true,
          "properties": {
            "method": {"type": "string"},
            "origin_lon": {"type": "number"},
            "origin_lat": {"type": "number"},
            "unit": {"type": "string"}
          }
        }
      }
    },
    "geometry_objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["object_guid", "semantic_component"],
        "additionalProperties": false,
        "properties": {
          "object_guid": {
            "type": "string",
            "minLength": 1
          },
          "semantic_component": {
            "type": "string",
            "minLength": 1
          },
          "local_coord": {
            "type": "object",
            "required": ["x", "y", "z"],
            "additionalProperties": false,
            "properties": {
              "x": {"type": "number"},
              "y": {"type": "number"},
              "z": {"type": "number"}
            }
          },
          "geo_coord": {
            "type": "object",
            "required": ["lon", "lat", "alt"],
            "additionalProperties": false,
            "properties": {
              "lon": {"type": "number"},
              "lat": {"type": "number"},
              "alt": {"type": "number"}
            }
          },
          "transform_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "oneOf": [
          {
            "required": ["local_coord", "geo_coord"]
          },
          {
            "required": ["transform_ref"],
            "anyOf": [
              {"required": ["local_coord"]},
              {"required": ["geo_coord"]}
            ]
          }
        ]
      }
    }
  }
}
